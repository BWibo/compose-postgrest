# General settings ----------------------------------------

DOMAIN=localhost

# PostgreSQL superuser -------------------------------------

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# PostgREST database and user ------------------------------

POSTGREST_DB=postgrest
POSTGREST_USER=postgrest_user
POSTGREST_PASSWORD=postgrest_pass
POSTGREST_SUBPATH=/postgrest

# PostgREST schema -----------------------------------------

DB_ANON_ROLE=anon
DB_SCHEMA=testschema

# PostgREST settings ---------------------------------------

PGRST_DB_MAX_ROWS=1000
PGRST_DB_POOL=2
PGRST_DB_POOL_ACQUISITION_TIMEOUT=10

# Production recommendations (uncomment as needed):
# PGRST_DB_POOL=10                        # Match expected concurrency (default: 10)
# PGRST_DB_POOL_MAX_IDLETIME=30           # Close idle connections after N seconds (default: 30)
# PGRST_DB_POOL_MAX_LIFETIME=1800         # Recycle connections after N seconds (default: 1800)
# PGRST_CLIENT_ERROR_VERBOSITY=minimal    # Don't leak DB error details to clients
# PGRST_OPENAPI_MODE=disabled             # Hide schema discovery from public
# PGRST_DB_AGGREGATES_ENABLED=false       # Disable aggregates to prevent expensive query DoS
# PGRST_LOG_LEVEL=warn                    # Log level: error (default), warn, info
# PGRST_ADMIN_SERVER_PORT=3001            # Health check endpoint for monitoring
